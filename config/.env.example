# Application
APP_NAME="AI-Agents"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost
SECURITY_SALT=__CHANGE_THIS_TO_A_RANDOM_STRING__

# Database
DB_HOST=db
DB_PORT=3306
DB_NAME=ai_agents
DB_USERNAME=ai_agents
DB_PASSWORD=secret
DB_TEST_NAME=ai_agents_test

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Queue (cakephp/queue)
QUEUE_DSN=redis://redis:6379

# GitHub Integration
GITHUB_API_URL=https://api.github.com

# Twilio (SMS / MFA)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Encryption key for sensitive fields (32-byte hex string)
ENCRYPTION_KEY=__CHANGE_THIS_TO_A_32_BYTE_HEX_STRING__

# MFA
MFA_OTP_TTL=300
MFA_OTP_LENGTH=6

# WhatsApp (Meta Cloud API)
# Per-agent secrets (phone_number_id, access_token) live in agent_contexts.
# WHATSAPP_APP_SECRET is shared across all agents on the same Meta App and
# is used to verify webhook signatures. WHATSAPP_VERIFY_TOKEN is the value
# you enter in Meta's webhook config UI.
WHATSAPP_API_URL=https://graph.facebook.com/v20.0
WHATSAPP_VERIFY_TOKEN=__GENERATE_RANDOM_STRING__
WHATSAPP_APP_SECRET=__SET_FROM_META_APP_SETTINGS__
WHATSAPP_OTP_TTL=600
WHATSAPP_OTP_LENGTH=6
WHATSAPP_OTP_MAX_ATTEMPTS=5
WHATSAPP_WINDOW_HOURS=24

# Slack
# Per-agent settings (app_id, bot_user_id, bot_token, signing_secret) live in agent_contexts.
# Each agent owns its own Slack App, so signing secrets are NOT global here.
SLACK_API_URL=https://slack.com/api

# Google Cloud Speech-to-Text + Text-to-Speech
# Used for transcribing inbound voice notes and (optionally) synthesising
# audio replies when users.preferred_reply_mode = 'audio' (or 'auto' after
# they sent a voice note). Empty key disables both endpoints — audio
# inbound falls back with an apology, audio outbound falls back to text.
GOOGLE_SPEECH_API_KEY=
GOOGLE_SPEECH_API_URL=https://speech.googleapis.com/v1
GOOGLE_TTS_API_URL=https://texttospeech.googleapis.com/v1
GOOGLE_SPEECH_LANGUAGE=en-US
GOOGLE_SPEECH_MODEL=latest_short
GOOGLE_TTS_VOICE=en-US-Standard-A
