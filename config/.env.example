# Application
APP_NAME="AI-Agents"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost
SECURITY_SALT=__CHANGE_THIS_TO_A_RANDOM_STRING__

# Database
DB_HOST=db
DB_PORT=3306
DB_NAME=ai_agents
DB_USERNAME=ai_agents
DB_PASSWORD=secret
DB_TEST_NAME=ai_agents_test

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Queue (cakephp/queue)
QUEUE_DSN=redis://redis:6379

# GitHub Integration
GITHUB_API_URL=https://api.github.com

# Twilio (SMS / MFA)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Encryption key for sensitive fields (32-byte hex string)
ENCRYPTION_KEY=__CHANGE_THIS_TO_A_32_BYTE_HEX_STRING__

# MFA
MFA_OTP_TTL=300
MFA_OTP_LENGTH=6

# WhatsApp (Meta Cloud API)
# Per-agent secrets (phone_number_id, access_token, app_secret) live in agent_contexts.
# Settings here are global: shared verify-token, OTP behaviour, 24h window length.
WHATSAPP_API_URL=https://graph.facebook.com/v20.0
WHATSAPP_VERIFY_TOKEN=__GENERATE_RANDOM_STRING__
WHATSAPP_OTP_TTL=600
WHATSAPP_OTP_LENGTH=6
WHATSAPP_OTP_MAX_ATTEMPTS=5
WHATSAPP_WINDOW_HOURS=24
